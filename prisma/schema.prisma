// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  // output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

model Project {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  description String
  repoUrl     String?
  liveUrl     String?
  featured    Boolean @default(false)

  companyId    Int
  company      Company             @relation(fields: [companyId], references: [id])
  technologies ProjectTechnology[] @relation("ProjectToProjectTechnology")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          Int     @id @default(autoincrement())
  title       String  @unique
  description String
  imgUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

model Technology {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  nomenclature String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects ProjectTechnology[] @relation("TechnologyToProjectTechnology")
}

model ProjectTechnology {
  projectId    Int
  technologyId Int

  project    Project    @relation("ProjectToProjectTechnology", fields: [projectId], references: [id])
  technology Technology @relation("TechnologyToProjectTechnology", fields: [technologyId], references: [id])

  @@id([projectId, technologyId])
}
